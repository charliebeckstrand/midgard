{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"types": ["node", "vitest/globals"],
		"incremental": true,
		"tsBuildInfoFile": ".tsbuildinfo/main.tsbuildinfo"
	},
	"include": ["src", "tsup.config.ts"],
	"exclude": ["src/docs"]
}
