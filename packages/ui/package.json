{
	"name": "ui",
	"version": "0.1.0",
	"type": "module",
	"license": "MIT",
	"sideEffects": false,
	"files": [
		"dist",
		"LICENSE"
	],
	"exports": {
		"./core": {
			"types": "./src/core/index.ts",
			"default": "./src/core/index.ts"
		},
		"./hooks": {
			"types": "./src/hooks/index.ts",
			"default": "./src/hooks/index.ts"
		},
		"./layouts": {
			"types": "./src/layouts/index.ts",
			"default": "./src/layouts/index.ts"
		},
		"./primitives/*": {
			"types": "./src/primitives/*/index.ts",
			"default": "./src/primitives/*/index.ts"
		},
		"./providers/*": {
			"types": "./src/providers/*/index.ts",
			"default": "./src/providers/*/index.ts"
		},
		"./types": {
			"types": "./src/types/index.ts",
			"default": "./src/types/index.ts"
		},
		"./modules/*": {
			"types": "./src/modules/*/index.ts",
			"default": "./src/modules/*/index.ts"
		},
		"./*": [
			{
				"types": "./src/components/*/index.ts",
				"default": "./src/components/*/index.ts"
			},
			{
				"types": "./src/modules/*/index.ts",
				"default": "./src/modules/*/index.ts"
			}
		]
	},
	"scripts": {
		"build": "tsup && tsc --emitDeclarationOnly --outDir dist",
		"dev": "trap 'kill 0' EXIT; tsup --watch --no-dts & vite --config vite.docs.config.ts & wait",
		"docs": "vite --config vite.docs.config.ts",
		"docs:build": "vite build --config vite.docs.config.ts",
		"docs:analyze": "ANALYZE=1 vite build --config vite.docs.config.ts",
		"docs:preview": "vite preview --config vite.docs.config.ts --port 3456",
		"test": "vitest run",
		"test:browser": "vitest run --config vitest.browser.config.ts",
		"test:a11y": "vitest run src/__tests__/a11y",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:changed": "vitest run --changed",
		"test:related": "vitest related --run",
		"bench": "vitest bench --run --config vitest.bench.config.ts",
		"check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json && tsc --noEmit -p tsconfig.docs.json",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --write --config-path=../.. ."
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@floating-ui/react": "^0.27.19",
		"@internationalized/date": "^3.10.0",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.23",
		"@types/d3-geo": "^3.1.0",
		"@types/topojson-client": "^3.1.5",
		"card-validator": "^10.0.4",
		"clsx": "^2.0.0",
		"d3-geo": "^3.1.1",
		"lucide-react": "^1.21.0",
		"marked": "^18.0.5",
		"motion": "^12.0.0",
		"pdfjs-dist": "^5.6.205",
		"shiki": "^3.23.0",
		"tailwind-merge": "^3.5.0",
		"tinykeys": "^4.0.0",
		"topojson-client": "^3.1.0"
	},
	"peerDependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest-axe": "^3.5.9",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "4.1.8",
		"@vitest/browser-playwright": "4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"jest-axe": "^10.0.0",
		"jsdom": "^29.0.2",
		"playwright": "1.56.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rollup-plugin-visualizer": "^6.0.0",
		"tailwindcss": "^4.3.0",
		"ts-morph": "^28.0.0",
		"tsup": "^8.5.1",
		"tsx": "^4.19.0",
		"typescript": "^6.0.3",
		"us-atlas": "^3.0.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"world-atlas": "^2.0.2"
	}
}