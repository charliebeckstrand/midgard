{
	"name": "ui",
	"version": "0.1.0",
	"type": "module",
	"license": "MIT",
	"sideEffects": false,
	"files": [
		"dist",
		"LICENSE"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./hooks": {
			"types": "./src/hooks/index.ts",
			"default": "./src/hooks/index.ts"
		},
		"./layouts": {
			"types": "./src/layouts/index.ts",
			"default": "./src/layouts/index.ts"
		},
		"./types": {
			"types": "./src/types/index.ts",
			"default": "./src/types/index.ts"
		},
		"./theme.css": "./src/theme.css",
		"./*": {
			"types": "./src/components/*/index.ts",
			"default": "./src/components/*/index.ts"
		}
	},
	"scripts": {
		"build": "tsup && tsc --emitDeclarationOnly --outDir dist",
		"dev": "trap 'kill 0' EXIT; tsup --watch --no-dts & vite --config vite.docs.config.ts & wait",
		"docs": "vite --config vite.docs.config.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"bench": "vitest bench --run --config vitest.bench.config.ts",
		"check-types": "tsc --noEmit",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --write --config-path=../.. ."
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@floating-ui/react": "^0.27.19",
		"@tanstack/react-virtual": "^3.13.23",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.0.0",
		"lucide-react": "^1.7.0",
		"maplibre-gl": "^5.23.0",
		"motion": "^12.0.0",
		"pdfjs-dist": "^5.6.205",
		"shiki": "^3.23.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.3.3",
		"@types/react": "^19.1.6",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.5",
		"jsdom": "^29.0.2",
		"react": "^19.1.0",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.1",
		"tinybench": "^6.0.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.5"
	}
}