{
	"name": "catalyst",
	"version": "0.1.0",
	"description": "Geist-inspired UI components for React",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write ."
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"@headlessui/react": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.0.0",
		"motion": "^12.0.0"
	},
	"peerDependencies": {
		"next": ">=14.0.0",
		"react": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.3.3",
		"@types/react": "^19.1.6",
		"react": "^19.1.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
