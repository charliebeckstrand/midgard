{
	"name": "docs-extractor",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"check-types": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"test:related": "vitest related --run",
		"test:changed": "base=$(git merge-base HEAD origin/main) && vitest run --passWithNoTests --changed=\"$base\""
	},
	"dependencies": {
		"typescript": "6.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@types/node": "^25.3.3",
		"vitest": "^4.1.8"
	}
}
