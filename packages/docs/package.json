{
	"name": "docs",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		"./engine": {
			"types": "./src/engine/index.ts",
			"default": "./dist/engine.js"
		},
		"./extractor": {
			"types": "./src/extractor/index.ts",
			"default": "./dist/extractor.js"
		},
		"./adapters": {
			"types": "./src/adapters/index.ts",
			"default": "./dist/adapters.js"
		},
		"./vite": {
			"types": "./src/vite/index.ts",
			"default": "./dist/vite.js"
		},
		"./scan": {
			"types": "./src/vite/scan.ts",
			"default": "./dist/scan.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"test:related": "vitest related --run",
		"test:changed": "base=$(git merge-base HEAD origin/main) && vitest run --passWithNoTests --changed=\"$base\""
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@vitejs/plugin-react": "^6.0.1",
		"marked": "^18.0.5",
		"typescript-6": "npm:typescript@6.0.3",
		"yaml": "^2.8.0"
	},
	"peerDependencies": {
		"vite": "^8.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.15",
		"tsup": "^8.5.1",
		"typescript": "^7.0.2",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
