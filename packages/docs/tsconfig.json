{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"types": ["node", "vitest/globals", "vite/client"],
		"incremental": true,
		"tsBuildInfoFile": ".tsbuildinfo/main.tsbuildinfo",
		"noEmit": true
	},
	"include": ["src", "tsup.config.ts", "vitest.config.ts", "vitest.bench.config.ts"]
}
