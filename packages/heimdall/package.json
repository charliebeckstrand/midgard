{
	"name": "heimdall",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/session.js",
	"types": "./src/session.ts",
	"exports": {
		".": {
			"types": "./src/session.ts",
			"import": "./dist/session.js",
			"default": "./dist/session.js"
		},
		"./config": {
			"types": "./src/config.ts",
			"import": "./dist/config.js",
			"default": "./dist/config.js"
		},
		"./proxy": {
			"types": "./src/proxy.ts",
			"import": "./dist/proxy.js",
			"default": "./dist/proxy.js"
		},
		"./login-page": {
			"types": "./src/components/login-page.tsx",
			"import": "./dist/login-page.js",
			"default": "./dist/login-page.js"
		},
		"./register-page": {
			"types": "./src/components/register-page.tsx",
			"import": "./dist/register-page.js",
			"default": "./dist/register-page.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write ."
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"catalyst": "workspace:*",
		"clsx": "^2.1.1",
		"reactbits": "workspace:*"
	},
	"peerDependencies": {
		"next": "^15.0.0 || ^16.0.0",
		"react": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@headlessui/react": "^2.0.0",
		"@types/node": "^25.3.3",
		"@types/react": "^19.1.6",
		"next": "^16.1.0",
		"react": "^19.1.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
