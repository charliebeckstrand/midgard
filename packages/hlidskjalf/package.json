{
	"name": "hlidskjalf",
	"version": "0.0.1",
	"description": "Terminal dashboard for pnpm monorepo dev processes",
	"type": "module",
	"license": "MIT",
	"bin": {
		"hlidskjalf": "./dist/index.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"keywords": [
		"monorepo",
		"pnpm",
		"dev",
		"dashboard",
		"terminal",
		"cli"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"prepublishOnly": "tsup"
	},
	"dependencies": {
		"ink": "^5.2.1",
		"react": "^18.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^22.15.33",
		"@types/react": "^18.3.23",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
