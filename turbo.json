{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "check-types": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "tsconfig.json", "../../tsconfig.base.json", "../../tsconfig.nextjs.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["src/**", "app/**", "../../biome.json"]
    }
  }
}
