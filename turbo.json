{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["BIFROST_URL"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/postcss.config.mjs"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "check-types": {
      "inputs": [
        "src/**",
        "app/**",
        "*.config.ts",
        "tsconfig.json",
        "tsconfig.scripts.json",
        "tsconfig.docs.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.nextjs.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["src/**", "app/**", "$TURBO_ROOT$/biome.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "app/**",
        "vitest.config.ts",
        "tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json"
      ]
    },
    "//#knip": {
      "inputs": [
        "knip.json",
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "postcss.config.mjs",
        "apps/**",
        "packages/**"
      ]
    }
  }
}
