{
	"name": "docs-app",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"check-types": "tsc --noEmit && node --experimental-strip-types scripts/check-fences.ts",
		"test": "vitest run --passWithNoTests",
		"test:related": "vitest related --run --passWithNoTests",
		"test:changed": "base=$(git merge-base HEAD origin/main) && vitest run --passWithNoTests --changed=\"$base\""
	},
	"dependencies": {
		"lucide-react": "^1.21.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"ui": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@tailwindcss/vite": "^4.2.1",
		"docs": "workspace:*",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^7.0.2",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
