{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"baseUrl": ".",
		"jsx": "preserve",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./app/*"]
		}
	},
	"include": ["next-env.d.ts", "app", "**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules", ".next"]
}
