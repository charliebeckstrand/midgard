{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignore": [".mcp-servers/**"],
	"ignoreBinaries": ["wait"],
	"ignoreUnresolved": ["next"],
	"ignoreExportsUsedInFile": true,
	"workspaces": {
		".": {
			"entry": ["postcss.config.mjs"]
		},
		"apps/admin": {
			"entry": ["next.config.{js,ts,mjs}"],
			"ignoreDependencies": ["@tailwindcss/postcss"]
		},
		"apps/docs": {
			"entry": ["index.html"]
		},
		"packages/*": {
			"entry": ["src/**/index.ts"]
		},
		"packages/docs": {
			"entry": ["src/**/index.ts"],
			"ignore": ["src/__tests__/fixtures/**"]
		},
		"packages/ui": {
			"entry": [
				"src/**/index.ts",
				"src/__tests__/**/setup/*.ts"
			]
		}
	}
}
