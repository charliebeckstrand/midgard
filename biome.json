{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"quoteStyle": "single"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"performance": {
				"noImgElement": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": [
				"packages/ui/**",
				"!packages/ui/**/__tests__/**",
				"!packages/ui/**/*.test.ts",
				"!packages/ui/**/*.test.tsx",
				"!packages/ui/**/*.bench.ts",
				"!packages/ui/src/docs/**"
			],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveCognitiveComplexity": "warn"
					}
				}
			}
		}
	],
	"files": {
		"includes": ["**/*.ts", "**/*.tsx", "!**/dist", "!**/.next", "!**/next-env.d.ts"],
		"ignoreUnknown": true
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false
	}
}
